{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "now.schema.json",
  "title": "Now",
  "description": "What's happening this week. Week-level granularity by design. content/now.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["updated", "items"],
  "properties": {
    "updated": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "items": {
      "type": "array",
      "items": { "$ref": "bilingual.schema.json" }
    }
  }
}
