{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feed-entry.schema.json",
  "title": "Feed entry",
  "description": "One curated portfolio entry. One file per entry: content/feed/YYYY-MM-DD-slug.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "date", "type", "tags", "narrative", "technical", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "YYYY-MM-DD-slug, matches the filename without .json"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "type": {
      "type": "string",
      "enum": ["decision", "problem-solved", "shipped", "learning"],
      "description": "Maps 1:1 to the four rubric criteria; doubles as a visual badge"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "minItems": 1
    },
    "narrative": { "$ref": "bilingual.schema.json" },
    "technical": { "$ref": "bilingual.schema.json" },
    "outcome": { "$ref": "bilingual.schema.json" },
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Optional id of a project this entry belongs to (content/projects/<id>.json)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published"]
    }
  }
}
