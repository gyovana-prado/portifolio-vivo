{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "project.schema.json",
  "title": "Project",
  "description": "One file per project: content/projects/<id>.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "featured", "title", "summary", "stack", "period"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "featured": { "type": "boolean" },
    "title": { "$ref": "bilingual.schema.json" },
    "summary": { "$ref": "bilingual.schema.json" },
    "case_study": { "$ref": "bilingual.schema.json" },
    "stack": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "links": {
      "type": "object",
      "additionalProperties": { "type": "string", "format": "uri" },
      "properties": {
        "repo": { "type": "string", "format": "uri" },
        "live": { "type": "string", "format": "uri" }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start"],
      "properties": {
        "start": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "end": {
          "anyOf": [
            { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
