---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import type { Lang } from '../lib/content';
import { ui } from '../lib/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Optional schema.org JSON-LD object, rendered in <head>. */
  jsonLd?: Record<string, unknown>;
}

const { lang, title, description, jsonLd } = Astro.props;
const strings = ui[lang];

// The "other language" URL for the switcher, and this language's home.
const altHref = lang === 'en' ? '/pt/' : '/';
const base = lang === 'en' ? '/' : '/pt/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="pt" href={new URL('/pt/', Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Feed" href={new URL('/rss.xml', Astro.site)} />
    <!-- Continuidade: cross-fade between EN/PT instead of a hard reload. -->
    <ClientRouter />
    <!-- Gate for reveal animations: without JS, .reveal styles never apply. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <a class="skip-link" href="#main">{strings.skipToContent}</a>
    <nav class="topbar">
      <div class="wrap topbar-inner">
        <div class="nav-links">
          <a href={`${base}#now`} data-spy="now">{strings.now}</a>
          <a href={`${base}#feed`} data-spy="feed">{strings.feed}</a>
          <a href={`${base}#projects`} data-spy="projects">{strings.projects}</a>
          <a href={`${base}#experience`} data-spy="experience">{strings.experience}</a>
        </div>
        <a class="lang-switch" href={altHref}>{strings.switchLang}</a>
      </div>
    </nav>
    <main id="main" class="wrap">
      <slot />
    </main>
    <footer class="wrap site-footer">
      <span class="faint">
        Built with the <a href="https://github.com/gyovana-prado/portifolio-vivo">Living Portfolio</a> engine.
      </span>
    </footer>

    <!-- Respiração: reveal .reveal elements as they enter the viewport, with a
         small stagger per batch. Inline so it can never fail to load; re-runs
         after every view transition via astro:page-load. -->
    <script is:inline>
      (function () {
        function initReveal() {
          var els = Array.prototype.slice.call(
            document.querySelectorAll('.reveal:not(.in-view)')
          );
          if (!els.length) return;
          var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!('IntersectionObserver' in window) || reduced) {
            els.forEach(function (el) { el.classList.add('in-view'); });
            return;
          }
          var io = new IntersectionObserver(
            function (entries) {
              var batch = 0;
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                entry.target.style.transitionDelay =
                  Math.min(batch++ * 70, 490) + 'ms';
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              });
            },
            { rootMargin: '0px 0px -10% 0px' }
          );
          els.forEach(function (el) { io.observe(el); });
        }
        document.addEventListener('astro:page-load', initReveal);
        if (document.readyState !== 'loading') initReveal();
        else document.addEventListener('DOMContentLoaded', initReveal);
      })();
    </script>

    <!-- Wayfinding: acende o link da nav da seção que está em vista. Um único
         IntersectionObserver marca a seção mais visível como ativa. -->
    <script is:inline>
      (function () {
        function initSpy() {
          var links = {};
          Array.prototype.forEach.call(
            document.querySelectorAll('.nav-links a[data-spy]'),
            function (a) { links[a.getAttribute('data-spy')] = a; }
          );
          var ids = Object.keys(links);
          if (!ids.length || !('IntersectionObserver' in window)) return;
          var visible = {};
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                visible[e.target.id] = e.isIntersecting ? e.intersectionRatio : 0;
              });
              var best = null, bestRatio = 0;
              ids.forEach(function (id) {
                if ((visible[id] || 0) > bestRatio) { bestRatio = visible[id]; best = id; }
              });
              ids.forEach(function (id) {
                links[id].classList.toggle('active', id === best);
              });
            },
            { rootMargin: '-52px 0px -55% 0px', threshold: [0, 0.25, 0.5, 1] }
          );
          ids.forEach(function (id) {
            var sec = document.getElementById(id);
            if (sec) io.observe(sec);
          });
        }
        document.addEventListener('astro:page-load', initSpy);
        if (document.readyState !== 'loading') initSpy();
        else document.addEventListener('DOMContentLoaded', initSpy);
      })();
    </script>

    <style>
      .topbar {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(11, 12, 14, 0.82);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
      }
      .topbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 10px;
        padding-bottom: 10px;
      }
      .nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        font-size: 0.8rem;
      }
      .nav-links a {
        color: var(--text-dim);
        transition: color 0.15s ease-out;
      }
      .nav-links a:hover {
        color: var(--text);
        text-decoration: none;
      }
      /* Wayfinding: o link da seção visível fica aceso, com um traço de accent. */
      .nav-links a.active {
        color: var(--text);
      }
      .nav-links a.active::after {
        content: '';
        display: block;
        height: 2px;
        margin-top: 2px;
        background: var(--accent);
        border-radius: 2px;
      }
      .lang-switch {
        font-size: 0.8rem;
        color: var(--text-dim);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 4px 12px;
      }
      .lang-switch:hover {
        color: var(--text);
        text-decoration: none;
        border-color: var(--accent-dim);
      }
      .site-footer {
        padding: 40px 24px 60px;
        font-size: 0.8rem;
        border-top: 1px solid var(--border);
        margin-top: 20px;
      }
    </style>
  </body>
</html>
